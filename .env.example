# Copy to .env.local and fill in your Supabase project credentials.
# Publishable keys are designed for browser usage; do not put service-role keys here.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Optional: base path for the deployed app (e.g. /repo-name/ for GitHub Pages).
# Defaults to / when unset.
# VITE_BASE=/time-picker-vote/
